use flake

# Watch for changes to trigger environment reload.
# nix-direnv watches flake inputs (flake.nix, flake.lock) automatically;
# imported modules under flake/ are not auto-watched and need explicit entries.
watch_file pyproject.toml
watch_file uv.lock
watch_file flake/python-axis.nix
watch_file flake/devshells.nix
watch_file flake/pre-commit.nix
watch_file flake/treefmt.nix

# Setup Python dependencies
uv sync --extra test --quiet || log_error "uv sync failed"
PATH_add "$PWD/.venv/bin"
